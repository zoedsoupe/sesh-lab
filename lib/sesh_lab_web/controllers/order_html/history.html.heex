<Layouts.app flash={@flash}>
  <section class="stack-5">
    <header class="stack-1">
      <h1 class="text-xl text-mono">Meus ingressos</h1>
      <p class="text-xs text-dim">
        Compras feitas neste aparelho. Toque pra ver status, PIX e QR.
      </p>
    </header>

    <div class="stack-2" data-order-history></div>

    <a href={~p"/"} class="btn btn--ghost btn--block">Voltar</a>
  </section>
</Layouts.app>
