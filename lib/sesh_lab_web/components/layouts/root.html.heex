<!DOCTYPE html>
<html lang="pt-br" style={assigns[:accent] && "--accent: #{@accent}"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="theme-color" content="#05070A" />
    <link rel="manifest" href={~p"/manifest.webmanifest"} />
    <link rel="icon" href={~p"/images/favicon.svg"} type="image/svg+xml" />
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="apple-touch-icon" href={~p"/images/apple-touch-icon.png"} />
    <link
      rel="preload"
      href={~p"/fonts/jetbrains-mono-400.woff2"}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={~p"/fonts/vt323-400.woff2"}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <.live_title default="SESH LAB.">
      {assigns[:page_title]}
    </.live_title>
    <% seo = SeshLabWeb.SEO.build(assigns, unverified_url(@conn, @conn.request_path)) %>
    <meta name="description" content={seo.description} />
    <meta :if={seo.no_index} name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={seo.url} />

    <meta property="og:type" content={seo.type} />
    <meta property="og:site_name" content={seo.site_name} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.url} />
    <meta :if={seo.image} property="og:image" content={seo.image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta :if={seo.image} name="twitter:image" content={seo.image} />

    <script :if={assigns[:jsonld]} type="application/ld+json">
      {Phoenix.HTML.raw(@jsonld)}
    </script>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script
      :if={assigns[:scanner]}
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/scanner.js"}
    >
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-base text-fg text-sans">
    {@inner_content}
  </body>
</html>
